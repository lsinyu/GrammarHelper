<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="8dp">

    <!-- Bot Message Text -->
    <TextView
        android:id="@+id/chatBotText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        android:padding="12dp"
        android:textColor="?android:textColorPrimary"
        android:textSize="16sp" />

    <!-- Quiz Container -->
    <LinearLayout
        android:id="@+id/quizContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="vertical"
        android:visibility="gone" />

    <!-- Submit Quiz Button -->
    <Button
        android:id="@+id/btnSubmitQuiz"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Submit Answers"
        android:visibility="gone" />

    <!-- Rewrite Container -->
    <LinearLayout
        android:id="@+id/rewriteContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Rewrite Title -->
        <TextView
            android:id="@+id/rewriteTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Professional Version"
            android:textColor="?android:textColorPrimary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Rewrite Content -->
        <TextView
            android:id="@+id/rewriteContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="?attr/colorSurface"
            android:padding="12dp"
            android:textColor="?android:textColorPrimary"
            android:textSize="14sp" />

        <!-- Rewrite Pager Info -->
        <TextView
            android:id="@+id/rewritePagerInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="1 / 3"
            android:textColor="?android:textColorSecondary"
            android:textSize="12sp" />

        <!-- Navigation Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btnPrevRewrite"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="◀ Previous"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnNextRewrite"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Next ▶" />
        </LinearLayout>

        <!-- Style Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btnStyleProf"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Professional"
                android:layout_marginEnd="4dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

            <Button
                android:id="@+id/btnStyleCasual"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Casual"
                android:layout_marginEnd="4dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

            <Button
                android:id="@+id/btnStyleShort"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Short"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
        </LinearLayout>

        <!-- Copy Button -->
        <ImageButton
            android:id="@+id/btnCopyRewrite"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="end"
            android:layout_marginTop="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Copy"
            android:src="@android:drawable/ic_menu_save"
            app:tint="?android:textColorPrimary" />
    </LinearLayout>

</LinearLayout>